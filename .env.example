# --- PostgreSQL ---
POSTGRES_DB=docent
POSTGRES_USER=docent
POSTGRES_PASSWORD=change-me

# Used by the backend. Host "db" is the compose service name.
DATABASE_URL=postgresql+psycopg://docent:change-me@db:5432/docent

# --- Backend ---
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-openssl-rand-hex-32
# Access code REQUIRED to register. Share it only with people you want to let in.
# If empty, registration is closed entirely. `start.sh` generates one on first run.
INVITE_CODE=
# Email shown on the login/register pages so people know where to request an
# access code or a password reset. Strongly recommended.
CONTACT_EMAIL=
# Optional: community name shown in the header, on the login page, and on the
# public impact page (e.g. "UTK Physics Outreach"). Admins can also set it in
# the app. Empty = plain DOCENT branding.
SITE_NAME=
# Optional: serve a public read-only impact summary at /impact (true/false).
# Default false; admins can also toggle it in the app.
PUBLIC_PAGE=false
# Optional: your instance's public web address, e.g. https://docent.your-org.edu.
# Admins can also set this in the app (Admin → Site address & domain setup), where
# it drives a copy-paste DNS request for your IT department.
SITE_URL=
# GO LIVE OVER HTTPS: set this to your bare domain (e.g. docent.your-org.edu) and
# re-run ./scripts/start.sh. That starts a bundled Caddy container that serves
# HTTPS on 443 with an automatic, auto-renewing certificate and proxies to the
# app — no separate proxy to install. LEAVE EMPTY to just run on http://localhost
# (the default: no Caddy, nothing exposed to the network). Requires the domain's
# DNS to point at this machine and inbound ports 80 + 443 to be open.
SITE_DOMAIN=
# Login session lifetime in days.
ACCESS_TOKEN_DAYS=7
# auto (recommended): the login cookie is marked Secure only when the connection
# is HTTPS (honors a reverse proxy's X-Forwarded-Proto), so login works over both
# plain http and https. Force with true/false if you need to.
COOKIE_SECURE=auto

# --- Frontend / proxy ---
# Host port the web UI is published on. Default 8080 so a TLS reverse proxy
# (Caddy/nginx/Traefik) can own 80/443 and forward a subdomain here.
HTTP_PORT=8080
# Interface the port binds to. Default 127.0.0.1 = reachable ONLY from this host
# (i.e. only through your TLS reverse proxy), never directly over plain HTTP from
# the network. Set 0.0.0.0 only on a trusted private LAN with no proxy.
BIND_HOST=127.0.0.1

# --- Backups ---
# Hour of day (00-23, container-local time = UTC) for the nightly dump.
BACKUP_HOUR=02
