# --- PostgreSQL ---
POSTGRES_DB=docent
POSTGRES_USER=docent
POSTGRES_PASSWORD=change-me

# Used by the backend. Host "db" is the compose service name.
DATABASE_URL=postgresql+psycopg://docent:change-me@db:5432/docent

# --- Backend ---
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-openssl-rand-hex-32
# If set (non-empty), new registrations must supply this code.
INVITE_CODE=
# Login session lifetime in days.
ACCESS_TOKEN_DAYS=7
# Set to false only when serving over plain http (e.g. local testing).
COOKIE_SECURE=true

# --- Frontend / proxy ---
# Host port the web UI is published on. Default 8080 so a TLS reverse proxy
# (Caddy/nginx/Traefik) can own 80/443 and forward a subdomain here.
HTTP_PORT=8080

# --- Backups ---
# Hour of day (00-23, container-local time = UTC) for the nightly dump.
BACKUP_HOUR=02
